{% extends "layouts/main.html" %}

{% set pageTitle = "Email notification" %}

{% block beforeContent %}{% endblock %}

{% block content %}
<div class="govuk-grid-row">
  <div class="govuk-grid-column-full">                                              
    
    <h2 class="govuk-heading-m">Email preview</h2>  
    
    {# Metadata Section #}
    <p class="govuk-body">
      <strong>To:</strong> {{ data['your-full-name'] | default("Dean Falconer") }} ({{ data['your-email'] | default("dean@falconers-nest.co.uk") }})
    </p>
    <p class="govuk-body">
      <strong>Subject:</strong> Change of service for your CITES permit application
    </p>
    
    <hr class="govuk-section-break govuk-section-break--l govuk-section-break--visible">

    {# Email Body #}
    <div class="govuk-panel__body">
      <p class="govuk-body">There have been changes which we would like to inform you about. </p>
      
      <p class="govuk-body">
        From CITES team<br>
        Animal and Plant Health Agency (APHA)
      </p>
    </div>
  </div>
</div>
{% endblock %}